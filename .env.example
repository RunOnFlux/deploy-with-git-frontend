# Orbit Deployment UI — Environment Variables Template
# Copy this file to .env and fill in the values.

# App
VITE_APP_URL=https://orbit.runonflux.io

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_GA_MEASUREMENT_ID=

# Payment Bridge (for Stripe + Flux price calculation)
VITE_PAYMENT_BRIDGE_URL=https://fiatpaymentsbridge.runonflux.io

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Firebase (optional — defaults to the shared FluxOS fluxcore-prod project)
# Set these to use your own Firebase project instead.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── SSO signing backend ────────────────────────────────────────────────────────
# 'self'     - server derives a deterministic Flux keypair per user using HMAC-SHA256
#              Works with any Firebase project. Requires SSO_SIGNING_SECRET below.
# 'fluxcore' - delegates signing to service.fluxcore.ai
#              Requires Firebase project to be 'fluxcore-prod' (the official FluxOS project)
SSO_PROVIDER=self

# Required when SSO_PROVIDER=self. Keep this secret and never change it in production
# (changing it will generate different zelid addresses for all existing email users).
# Generate with: openssl rand -hex 32
SSO_SIGNING_SECRET=

VITE_DEV_MOCK_FLUXCORE=false
